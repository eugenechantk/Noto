default_platform(:ios)

def required_env(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable: #{name}") if value.nil? || value.strip.empty?
  value
end

def boolean_env(name, default)
  value = ENV[name]
  return default if value.nil? || value.strip.empty?

  %w[1 true yes y].include?(value.downcase)
end

def app_store_connect_key
  app_store_connect_api_key(
    key_id: required_env("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: required_env("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_content: required_env("APP_STORE_CONNECT_API_KEY_BASE64"),
    is_key_content_base64: true,
    duration: 1200
  )
end

def sync_appstore_signing(readonly:)
  app_identifier = required_env("APP_IDENTIFIER")
  developer_team_id = required_env("DEVELOPER_TEAM_ID")
  match_git_url = required_env("MATCH_GIT_URL")

  match(
    type: "appstore",
    readonly: readonly,
    app_identifier: app_identifier,
    git_url: match_git_url,
    git_branch: ENV.fetch("MATCH_GIT_BRANCH", "main"),
    team_id: developer_team_id,
    api_key: app_store_connect_key
  )
end

def require_app_store_record(app_identifier)
  app_store_connect_key
  return if Spaceship::ConnectAPI::App.find(app_identifier)

  UI.user_error!(
    "App Store Connect app record is missing for #{app_identifier}. " \
    "Create it in App Store Connect first, then rerun this lane."
  )
end

platform :ios do
  desc "Verify the App Store Connect app record exists"
  lane :verify_app_store_record do
    require_app_store_record(required_env("APP_IDENTIFIER"))
  end

  desc "Create or refresh App Store signing assets in the match repository"
  lane :bootstrap_match do
    sync_appstore_signing(readonly: false)
  end

  desc "Build a signed Release archive and upload it to TestFlight"
  lane :deploy_testflight do
    setup_ci if ENV["CI"]

    app_identifier = required_env("APP_IDENTIFIER")
    developer_team_id = required_env("DEVELOPER_TEAM_ID")
    api_key = app_store_connect_key

    require_app_store_record(app_identifier)
    sync_appstore_signing(readonly: true)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Noto.xcodeproj",
      targets: ["Noto"],
      team_id: developer_team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{app_identifier}"
    ) if ENV["CI"]

    increment_build_number(
      xcodeproj: "Noto.xcodeproj",
      build_number: ENV["BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"]
    ) if ENV["BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"]

    build_app(
      project: "Noto.xcodeproj",
      scheme: ENV.fetch("FASTLANE_SCHEME", "Noto-iOS"),
      configuration: "Release",
      destination: "generic/platform=iOS",
      clean: true,
      export_method: "app-store",
      output_directory: "build/fastlane",
      output_name: "Noto.ipa",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          app_identifier => "match AppStore #{app_identifier}"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/fastlane/Noto.ipa",
      changelog: ENV["TESTFLIGHT_CHANGELOG"],
      skip_waiting_for_build_processing: !boolean_env("TESTFLIGHT_WAIT_FOR_PROCESSING", false)
    )
  end
end
